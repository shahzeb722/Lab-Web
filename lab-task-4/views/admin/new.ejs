<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Product | Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="admin-brand">Samsung Admin</div>
            <nav class="admin-nav">
                <a href="/admin/products" class="admin-nav-link">Products</a>
                <a href="/products" class="admin-nav-link">View Store</a>
                <a href="/" class="admin-nav-link">Home</a>
            </nav>
            <div class="admin-user">
                <span><%= currentUser ? currentUser.name : 'Admin' %></span>
                <form class="inline-form" method="POST" action="/logout">
                    <button class="link-button" type="submit">Logout</button>
                </form>
            </div>
        </aside>

        <main class="admin-main">
            <div class="admin-header">
                <div>
                    <h1>Add Product</h1>
                    <p class="admin-subtitle">Create a new product for the catalog.</p>
                </div>
                <a class="btn btn-outline" href="/admin/products">Back</a>
            </div>

            <% if (errors && errors.length) { %>
                <div class="admin-alert admin-alert--error">
                    <ul>
                        <% errors.forEach(function (error) { %>
                            <li><%= error %></li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <%- include('../partials/flash') %>

            <form class="admin-form" method="POST" action="/admin/products" enctype="multipart/form-data">
                <div class="admin-form-grid">
                    <div class="admin-field">
                        <label for="name">Product Name</label>
                        <input type="text" id="name" name="name" value="<%= formData.name || '' %>" required>
                    </div>
                    <div class="admin-field">
                        <label for="price">Price</label>
                        <input type="number" id="price" name="price" step="0.01" min="0" value="<%= formData.price || '' %>" required>
                    </div>
                    <div class="admin-field">
                        <label for="category">Category</label>
                        <select id="category" name="category" required>
                            <option value="">Select Category</option>
                            <% categories.forEach(function (category) { %>
                                <option value="<%= category %>" <%= formData.category === category ? 'selected' : '' %>><%= category %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="admin-field">
                        <label for="rating">Rating</label>
                        <input type="number" id="rating" name="rating" step="0.1" min="0" max="5" value="<%= formData.rating || '' %>" required>
                    </div>
                    <div class="admin-field">
                        <label for="stock">Stock</label>
                        <input type="number" id="stock" name="stock" min="0" value="<%= formData.stock || '' %>" required>
                    </div>
                    <div class="admin-field">
                        <label for="image">Product Image</label>
                        <input type="file" id="image" name="image" accept="image/*" required>
                    </div>
                </div>

                <div class="admin-field">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4"><%= formData.description || '' %></textarea>
                </div>

                <div class="admin-actions">
                    <button class="btn btn-black" type="submit">Save Product</button>
                    <a class="btn btn-outline" href="/admin/products">Cancel</a>
                </div>
            </form>
        </main>
    </div>
</body>
</html>
