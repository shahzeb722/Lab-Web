{
  "info": {
    "_postman_id": "7f9c1c1e-4c8c-4c5a-bc1c-9a5a9f3e2f1b",
    "name": "Lab Web - JWT API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login (JWT)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      },
      "response": []
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/products?page=1&sort=price_desc"
      },
      "response": []
    },
    {
      "name": "Products - By Id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/products/{{productId}}"
      },
      "response": []
    },
    {
      "name": "User - Profile (JWT)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/v1/user/profile"
      },
      "response": []
    },
    {
      "name": "Orders - Create (JWT)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"name\": \"Sample Item\",\n      \"quantity\": 1,\n      \"price\": 99.99\n    }\n  ],\n  \"total\": 99.99\n}"
        },
        "url": "{{baseUrl}}/api/v1/orders"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@samsung.com"
    },
    {
      "key": "adminPassword",
      "value": "Admin123!"
    },
    {
      "key": "productId",
      "value": ""
    }
  ]
}
