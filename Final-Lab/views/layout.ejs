<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- typeof title !== 'undefined' ? title : 'Samsung Clone' %></title>
    <meta name="description" content="Samsung Clone - Official Store Dashboard">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- jQuery CDN -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body>

    <!-- Utility Bar -->
    <div class="utility-bar">
        <div class="container">
            <div class="utility-left">
                <a href="#">For Business</a>
                <a href="#">Support</a>
            </div>
            <div class="utility-right">
                <% if (typeof user !== 'undefined' && user) { %>
                    <span style="color: #fff; margin-right: 15px; font-size: 12px; font-weight: 500;">Welcome, <%= user.name %>!</span>
                    <a href="/auth/logout">Logout</a>
                <% } else { %>
                    <a href="/auth/login">Sign In</a>
                    <a href="/auth/register">Create Account</a>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Main Header -->
    <header class="main-header">
        <div class="container header-flex">
            <div class="logo">
                <a href="/" style="text-decoration:none; color:inherit;">
                    <svg focusable="false" aria-label="Samsung" width="110" height="24" viewBox="0 0 130 29">
                        <g transform="translate(-250 -7)">
                            <path d="M0,13.835V12.482H4.609V14.2a1.558,1.558,0,0,0,1.724,1.6A1.509,1.509,0,0,0,8,14.6a2.237,2.237,0,0,0-.03-1.322C7.076,10.976.981,9.931.208,6.333a6.531,6.531,0,0,1-.029-2.4C.654,1.045,3.122,0,6.184,0c2.438,0,5.8.585,5.8,4.458V5.719H7.7V4.612a1.492,1.492,0,0,0-1.605-1.6,1.452,1.452,0,0,0-1.575,1.2,2.468,2.468,0,0,0,.03.922c.5,2.059,7.017,3.167,7.73,6.887a8.481,8.481,0,0,1,.029,2.921C11.892,17.893,9.336,19,6.244,19,3,19,0,17.8,0,13.835Zm55.837-.062V12.421h4.549v1.691a1.533,1.533,0,0,0,1.695,1.6,1.49,1.49,0,0,0,1.665-1.168,2.147,2.147,0,0,0-.029-1.292c-.863-2.274-6.9-3.319-7.671-6.917a6.37,6.37,0,0,1-.03-2.367c.476-2.859,2.944-3.9,5.946-3.9,2.409,0,5.739.615,5.739,4.427v1.23H63.449V4.643a1.485,1.485,0,0,0-1.575-1.6,1.4,1.4,0,0,0-1.546,1.168,2.463,2.463,0,0,0,.029.922C60.832,7.194,67.284,8.27,68,11.959a8.314,8.314,0,0,1,.029,2.89c-.416,2.952-2.943,4.028-6.005,4.028C58.811,18.877,55.837,17.678,55.837,13.773Zm16.293.647A7.18,7.18,0,0,1,72.1,13.25V.523h4.341V13.65a5.023,5.023,0,0,0,.029.677,1.682,1.682,0,0,0,3.271,0,4.852,4.852,0,0,0,.03-.677V.523h4.341V13.25c0,.339-.03.984-.03,1.169-.3,3.319-2.825,4.4-5.976,4.4S72.428,17.739,72.13,14.419Zm35.739-.185a9.539,9.539,0,0,1-.059-1.168V5.6c0-.308.029-.861.059-1.169.386-3.319,2.973-4.365,6.036-4.365,3.033,0,5.708,1.045,6.006,4.365A8.781,8.781,0,0,1,119.94,5.6v.584H115.6V5.2a3.791,3.791,0,0,0-.059-.677,1.777,1.777,0,0,0-3.42,0,3.772,3.772,0,0,0-.059.829v8.117a5.1,5.1,0,0,0,.03.677,1.707,1.707,0,0,0,1.813,1.291,1.633,1.633,0,0,0,1.754-1.291,2.554,2.554,0,0,0,.03-.677V10.883h-1.754V8.3H120v4.765a9.377,9.377,0,0,1-.06,1.168c-.3,3.228-3,4.366-6.036,4.366S108.166,17.462,107.869,14.235Zm-60.5,4.027L47.245,1.845,44.272,18.262H39.931L36.987,1.845l-.118,16.417H32.587L32.943.554h6.988L42.1,14.388,44.272.554h6.987l.386,17.708Zm-22.835,0L22.211,1.845,19.831,18.262H15.194L18.344,.554h7.642l3.152,17.708Zm72.665-.184L92.884,3.352l.238,14.726H88.9V.554h6.363l4.044,14.265L99.068.554h4.251V18.078Z" transform="translate(255 12)"></path>
                        </g>
                    </svg>
                </a>
            </div>

            <nav class="nav-links" id="navLinks">
                <a href="/shop" class="nav-item">Shop</a>
                <a href="/shop?category=mobile" class="nav-item">Mobile</a>
                <a href="/shop?category=tv-audio" class="nav-item">TV &amp; Audio</a>
                <a href="/shop?category=appliances" class="nav-item">Appliances</a>
                <a href="/sales" class="nav-item">Sales Dashboard</a>
                <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                  <a href="/admin" class="nav-item">Admin</a>
                <% } %>
            </nav>

            <div class="nav-icons" style="display: flex; align-items: center; gap: 1rem;">
                <span class="icon" id="searchIcon" style="cursor: pointer;">🔍</span>
                <a href="/cart" style="text-decoration: none; color: inherit; position: relative;">
                    <span class="icon">🛒</span>
                    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                        <span style="position: absolute; top: -8px; right: -12px; background: #e53e3e; color: #fff; font-size: 0.7rem; font-weight: bold; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; border-radius: 50%;"><%= cartCount %></span>
                    <% } %>
                </a>
                <div class="profile-dropdown" style="position: relative;">
                    <a href="<%= (typeof user !== 'undefined' && user) ? (user.role === 'admin' ? '/admin' : '/auth/logout') : '/auth/login' %>" style="text-decoration: none; color: inherit;">
                        <span class="icon" style="cursor: pointer;">👤</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Page Content (injected by express-ejs-layouts) -->
    <main>
        <div class="container" style="margin-top: 1rem;">
            <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
                <% success_msg.forEach(msg => { %>
                    <div style="background: #c6f6d5; color: #22543d; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; border: 1px solid #9ae6b4;"><%= msg %></div>
                <% }) %>
            <% } %>
            <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
                <% error_msg.forEach(msg => { %>
                    <div style="background: #fed7d7; color: #822727; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; border: 1px solid #feb2b2;"><%= msg %></div>
                <% }) %>
            <% } %>
        </div>
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="container">
            <p>Copyright &copy; 1995-2026 SAMSUNG All Rights Reserved.</p>
        </div>
    </footer>

    <script src="/js/script.js"></script>
    
    <!-- Search Modal Overlay -->
    <div id="searchModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; backdrop-filter: blur(5px);">
        <div style="position: absolute; top: 20%; left: 50%; transform: translateX(-50%); width: 90%; max-width: 600px; background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.15);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 style="margin: 0; font-size: 1.5rem; font-weight: 600; color: #000;">Search Products</h3>
                <span id="closeSearch" style="cursor: pointer; font-size: 1.5rem; font-weight: bold; color: #718096;">&times;</span>
            </div>
            <form action="/shop" method="GET" style="display: flex; gap: 1rem;">
                <input type="text" name="search" placeholder="What are you looking for?" required style="flex: 1; padding: 1rem; border: 1px solid #cbd5e0; border-radius: 8px; font-size: 1.125rem;">
                <button type="submit" style="padding: 1rem 2rem; background: #000; color: #fff; border: none; border-radius: 8px; font-size: 1.125rem; font-weight: 600; cursor: pointer;">Search</button>
            </form>
        </div>
    </div>
    
    <script>
      $(document).ready(function() {
        $('#searchIcon').on('click', function() {
          $('#searchModal').fadeIn(200);
          $('#searchModal input').focus();
        });
        $('#closeSearch').on('click', function() {
          $('#searchModal').fadeOut(200);
        });
        $('#searchModal').on('click', function(e) {
          if(e.target === this) {
            $(this).fadeOut(200);
          }
        });
      });
    </script>
</body>
</html>
