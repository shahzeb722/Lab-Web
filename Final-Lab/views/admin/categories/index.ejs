<div style="margin-bottom: 1rem; text-align: right;">
  <a href="/admin/categories/new" class="btn-primary">+ Add New Category</a>
</div>

<table class="admin-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Slug</th>
      <th>Description</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (categories.length > 0) { %>
      <% categories.forEach(category => { %>
        <tr>
          <td><%= category.name %></td>
          <td><%= category.slug %></td>
          <td><%= category.description %></td>
          <td style="display: flex; gap: 0.5rem;">
            <a href="/admin/categories/edit/<%= category._id %>" class="btn-primary" style="background: #4a5568;">Edit</a>
            <form action="/admin/categories/delete/<%= category._id %>" method="POST" style="display:inline;">
              <button type="submit" class="btn-danger" onclick="return confirm('Are you sure you want to delete this category?');">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td colspan="4" style="text-align: center; color: #718096;">No categories found.</td>
      </tr>
    <% } %>
  </tbody>
</table>

<% if (totalPages > 1) { %>
  <div style="margin-top: 2rem; display: flex; gap: 0.5rem; justify-content: center;">
    <% for(let i=1; i<=totalPages; i++) { %>
      <a href="/admin/categories?page=<%= i %>" style="padding: 0.5rem 1rem; border: 1px solid #cbd5e0; border-radius: 4px; text-decoration: none; <%= currentPage === i ? 'background: #2b6cb0; color: #fff;' : 'color: #4a5568;' %>"><%= i %></a>
    <% } %>
  </div>
<% } %>
