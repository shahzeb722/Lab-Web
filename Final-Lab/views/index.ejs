<!-- Hero Section -->
<section class="main-hero">
    <div class="hero-text">
        <p class="hero-tag">Introducing</p>
        <h2>Galaxy Z Fold7</h2>
        <p>Get up to $750 trade-in credit and $100 instant credit.</p>
        <div class="btn-group">
            <a href="/shop" class="btn btn-black">Shop Now</a>
            <a href="#" class="btn btn-outline">Learn More</a>
        </div>
    </div>
    <div class="hero-image">
        <img src="https://image-us.samsung.com/SamsungUS/home/mobile/smartphone/fold7/11192025/SDSAC-10044-BuyPageGallery-BBY_ZFold7_Thinnest_and_Lighest_Foldable_Copy.jpg?$product-details-jpg$" alt="Galaxy Z Fold7">
    </div>
</section>

<!-- Offer Grid -->
<section class="offer-grid">
    <div class="container">
        <div class="offer-card offer-card--split">
            <div class="card-content card-content--side">
                <h3>Bespoke AI 3-Door French Door</h3>
                <p>Upgrade to a smarter kitchen.</p>
                <a href="/shop">Shop Now</a>
            </div>
            <div class="card-img-wrap">
                <img src="/img/appliances.webp" alt="Bespoke AI 3-Door French Door">
            </div>
        </div>
        <div class="offer-card">
            <img src="/img/mini-led.webp" alt="Mini LED TV">
            <div class="card-content">
                <h3>Mini LED</h3>
                <p>Bring the gallery into your home.</p>
                <a href="/shop">Shop Now</a>
            </div>
        </div>
    </div>
</section>

<!-- Featured Deals Section -->
<section class="featured-deals container">
    <h2 class="section-title">Featured Deals</h2>
    <div class="featured-deals-container" id="featuredDealsContainer">
        <!-- Products will be dynamically loaded here -->
        <div class="loading-spinner" id="loadingSpinner">
            <p>Loading featured products...</p>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="categories container">
    <h2 class="section-title">Shop by Category</h2>
    <div class="cat-grid">
        <a href="/shop/category/mobile" class="cat-item" style="text-decoration: none; color: inherit;">
            <div class="circle-img">
                <img src="/img/mobile.webp" alt="Mobile">
            </div>
            <p>Mobile</p>
        </a>
        <a href="/shop/category/tv-audio" class="cat-item" style="text-decoration: none; color: inherit;">
            <div class="circle-img">
                <img src="/img/tv.webp" alt="TV">
            </div>
            <p>TV & Video</p>
        </a>
        <a href="/shop/category/appliances" class="cat-item" style="text-decoration: none; color: inherit;">
            <div class="circle-img">
                <img src="/img/appliances.webp" alt="Appliances">
            </div>
            <p>Appliances</p>
        </a>
        <a href="/shop" class="cat-item" style="text-decoration: none; color: inherit;">
            <div class="circle-img">
                <img src="/img/computer.webp" alt="Computing">
            </div>
            <p>Computers and Monitors</p>
        </a>
    </div>
</section>

<!-- Modal for Quick View -->
<div id="quickViewModal" class="modal">
    <div class="modal-content">
        <span class="modal-close">&times;</span>
        <div class="modal-body">
            <div class="modal-image">
                <img id="modalProductImage" src="" alt="Product">
            </div>
            <div class="modal-info">
                <h2 id="modalProductTitle"></h2>
                <div class="modal-rating">
                    <span id="modalProductRating"></span>
                    <span id="modalProductRatingCount"></span>
                </div>
                <p class="modal-description" id="modalProductDescription"></p>
                <div class="modal-price">
                    <span id="modalProductPrice"></span>
                </div>
                <a id="modalProductLink" href="/shop" class="btn btn-black modal-btn" style="text-decoration: none; display: inline-block; text-align: center;">View Details</a>
            </div>
        </div>
    </div>
</div>